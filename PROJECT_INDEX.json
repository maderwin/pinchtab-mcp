    {
      "name": "pinchtab/client",
      "path": "src/pinchtab/client.ts",
      "exports": ["pinch"],
      "purpose": "HTTP client for PinchTab API; auto-starts process if needed; Bearer auth support"
    },
    {
      "name": "pinchtab/process",
      "path": "src/pinchtab/process.ts",
      "exports": ["findPinchtabBin", "isPinchtabRunning", "ensurePinchtabRunning", "cleanup"],

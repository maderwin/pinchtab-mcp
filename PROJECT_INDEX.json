{
  "project": {
    "name": "pinchtab-mcp",
    "version": "1.0.0",
    "description": "MCP server for PinchTab browser automation — control Chrome via accessibility tree snapshots",
    "license": "MIT",
    "generated": "2026-03-04",
    "repository": "https://github.com/maderwin/pinchtab-mcp.git"
  },
  "stack": {
    "language": "TypeScript",
    "runtime": "Node.js >=18",
    "module": "ESM",
    "target": "ES2022",
    "moduleResolution": "Node16",
    "build": "rolldown",
    "testRunner": "vitest",
    "linter": "oxlint",
    "formatter": "oxfmt",
    "gitHooks": "lefthook"
  },
  "entryPoints": [
    {
      "type": "cli-binary",
      "path": "dist/index.js",
      "description": "Compiled MCP server, exposed via bin.pinchtab-mcp in package.json"
    },
    {
      "type": "dev",
      "path": "src/index.ts",
      "description": "Source entry for npm run dev (tsx)"
    },
    {
      "type": "tool-barrel",
      "path": "src/tools/index.ts",
      "description": "registerAllTools(server) — delegates to 4 tool modules"
    }
  ],
  "modules": [
    {
      "name": "index",
      "path": "src/index.ts",
      "exports": ["server", "main"],
      "purpose": "McpServer setup, tool registration, StdioTransport connect, signal handlers"
    },
    {
      "name": "config",
      "path": "src/config.ts",
      "exports": ["PINCHTAB_URL", "PINCHTAB_TOKEN", "PINCHTAB_BIN"],
      "purpose": "Environment variable parsing with defaults"
    },
    {
      "name": "utils",
      "path": "src/utils.ts",
      "exports": ["toJson"],
      "purpose": "toJson(value) — JSON.stringify with indent 2, undefined not null"
    },
    {
      "name": "pinchtab/client",
      "path": "src/pinchtab/client.ts",
      "exports": ["pinch"],
      "purpose": "HTTP client for PinchTab API; auto-starts process if needed; Bearer auth support"
    },
    {
      "name": "pinchtab/process",
      "path": "src/pinchtab/process.ts",
      "exports": ["findPinchtabBin", "isPinchtabRunning", "ensurePinchtabRunning", "cleanup"],
      "purpose": "PinchTab binary lifecycle management"
    },
    {
      "name": "tools/index",
      "path": "src/tools/index.ts",
      "exports": ["registerAllTools"],
      "purpose": "Barrel — calls all 4 register* functions"
    },
    {
      "name": "tools/instances",
      "path": "src/tools/instances.ts",
      "exports": ["registerInstanceTools"],
      "tools": ["pinchtab_list_instances"],
      "purpose": "Tab listing via GET /tabs"
    },
    {
      "name": "tools/navigation",
      "path": "src/tools/navigation.ts",
      "exports": ["registerNavigationTools"],
      "tools": ["pinchtab_navigate", "pinchtab_snapshot", "pinchtab_scroll", "pinchtab_wait"],
      "purpose": "Page navigation (POST /navigate), accessibility tree snapshots (GET /snapshot), scroll, wait"
    },
    {
      "name": "tools/interaction",
      "path": "src/tools/interaction.ts",
      "exports": ["registerInteractionTools"],
      "tools": ["pinchtab_click", "pinchtab_type", "pinchtab_press", "pinchtab_hover", "pinchtab_focus", "pinchtab_select"],
      "purpose": "User interaction via POST /action with element refs"
    },
    {
      "name": "tools/content",
      "path": "src/tools/content.ts",
      "exports": ["registerContentTools"],
      "tools": ["pinchtab_get_text", "pinchtab_screenshot", "pinchtab_eval", "pinchtab_pdf"],
      "purpose": "Content extraction (GET /text), screenshots (GET /screenshot), JS eval (POST /evaluate), PDF (GET /pdf)"
    }
  ],
  "api": {
    "note": "PinchTab v0.7.x uses flat routes in standalone mode — no instance/tab ID prefix",
    "routes": {
      "navigation": { "method": "POST", "path": "/navigate", "body": "{url}" },
      "text": { "method": "GET", "path": "/text" },
      "snapshot": { "method": "GET", "path": "/snapshot", "query": "?interactive&format=compact&diff=true" },
      "screenshot": { "method": "GET", "path": "/screenshot", "response": "{base64}" },
      "evaluate": { "method": "POST", "path": "/evaluate", "body": "{expression}" },
      "action": { "method": "POST", "path": "/action", "body": "{kind, ref, ...}" },
      "tabs": { "method": "GET", "path": "/tabs" },
      "pdf": { "method": "GET", "path": "/pdf" },
      "health": { "method": "GET", "path": "/health" }
    },
    "actionKinds": ["click", "humanClick", "type", "humanType", "fill", "press", "hover", "focus", "select", "scroll"],
    "envVars": {
      "CHROME_BINARY": "Path to browser binary (Yandex, Brave, Edge, etc.)",
      "BRIDGE_HEADLESS": "Run browser headless (default: true)",
      "BRIDGE_PORT": "HTTP server port (default: 9867)",
      "BRIDGE_TOKEN": "API authentication token",
      "CDP_URL": "WebSocket URL to connect to existing browser"
    }
  },
  "tools": [
    { "name": "pinchtab_list_instances", "category": "instances", "file": "src/tools/instances.ts", "route": "GET /tabs" },
    { "name": "pinchtab_navigate", "category": "navigation", "file": "src/tools/navigation.ts", "route": "POST /navigate" },
    { "name": "pinchtab_snapshot", "category": "navigation", "file": "src/tools/navigation.ts", "route": "GET /snapshot" },
    { "name": "pinchtab_scroll", "category": "navigation", "file": "src/tools/navigation.ts", "route": "POST /action" },
    { "name": "pinchtab_wait", "category": "navigation", "file": "src/tools/navigation.ts", "route": "local timer" },
    { "name": "pinchtab_click", "category": "interaction", "file": "src/tools/interaction.ts", "route": "POST /action" },
    { "name": "pinchtab_type", "category": "interaction", "file": "src/tools/interaction.ts", "route": "POST /action" },
    { "name": "pinchtab_press", "category": "interaction", "file": "src/tools/interaction.ts", "route": "POST /action" },
    { "name": "pinchtab_hover", "category": "interaction", "file": "src/tools/interaction.ts", "route": "POST /action" },
    { "name": "pinchtab_focus", "category": "interaction", "file": "src/tools/interaction.ts", "route": "POST /action" },
    { "name": "pinchtab_select", "category": "interaction", "file": "src/tools/interaction.ts", "route": "POST /action" },
    { "name": "pinchtab_get_text", "category": "content", "file": "src/tools/content.ts", "route": "GET /text" },
    { "name": "pinchtab_screenshot", "category": "content", "file": "src/tools/content.ts", "route": "GET /screenshot" },
    { "name": "pinchtab_eval", "category": "content", "file": "src/tools/content.ts", "route": "POST /evaluate" },
    { "name": "pinchtab_pdf", "category": "content", "file": "src/tools/content.ts", "route": "GET /pdf" }
  ],
  "tests": {
    "unit": [
      { "path": "src/__tests__/config.test.ts", "covers": "env var parsing and defaults" },
      { "path": "src/__tests__/client.test.ts", "covers": "HTTP client (JSON/text responses, error handling, auto-start)" },
      { "path": "src/__tests__/content.test.ts", "covers": "content tools (text, screenshot, eval, PDF)" },
      { "path": "src/__tests__/instances.test.ts", "covers": "tab listing tool" },
      { "path": "src/__tests__/interaction.test.ts", "covers": "interaction tools (click, type, press, hover, focus, select)" },
      { "path": "src/__tests__/navigation.test.ts", "covers": "navigation tools (navigate, snapshot, scroll, wait)" },
      { "path": "src/__tests__/process.test.ts", "covers": "PinchTab process lifecycle" },
      { "path": "src/__tests__/registration.test.ts", "covers": "tool registration verification" }
    ],
    "e2e": [
      { "path": "src/__tests__/e2e/browser.test.ts", "covers": "full browser automation (13 tests)", "requires": "PINCHTAB_E2E=1 + live PinchTab on localhost:9867" }
    ],
    "coverage": {
      "statements": 95.88,
      "branches": 89.18,
      "functions": 100,
      "lines": 95.88,
      "unitTests": 57,
      "e2eTests": 13
    },
    "commands": {
      "unit": "npm test",
      "coverage": "npm run test:coverage",
      "e2e": "npm run test:e2e",
      "watch": "npm run test:watch"
    }
  },
  "configuration": [
    { "file": "tsconfig.json", "purpose": "TypeScript compiler options" },
    { "file": "rolldown.config.ts", "purpose": "Build bundler config" },
    { "file": "vitest.config.ts", "purpose": "Unit test runner config" },
    { "file": "vitest.e2e.config.ts", "purpose": "E2E test runner config" },
    { "file": "oxlintrc.json", "purpose": "Linter rules (7 plugins, sort-keys, no-null, ESM)" },
    { "file": "lefthook.yml", "purpose": "Git hooks (pre-commit: lint+fmt, pre-push: tsc+test)" },
    { "file": ".node-version", "purpose": "Node.js version pin" },
    { "file": "cspell.json", "purpose": "Spell checker dictionary" },
    { "file": "commitlint.config.ts", "purpose": "Conventional commit message enforcement" }
  ],
  "dependencies": {
    "runtime": [
      { "name": "@modelcontextprotocol/sdk", "version": "^1.12.0", "purpose": "MCP server, tool registration, stdio transport" },
      { "name": "pinchtab", "version": "*", "purpose": "Browser automation binary (bundled)" }
    ],
    "dev": [
      { "name": "typescript", "version": "^5.7.0", "purpose": "Language" },
      { "name": "vitest", "version": "^3.0.0", "purpose": "Test runner" },
      { "name": "@vitest/coverage-v8", "version": "^3.2.4", "purpose": "Coverage reporter" },
      { "name": "oxlint", "version": "^0.16.0", "purpose": "Linter" },
      { "name": "oxfmt", "version": "^0.36.0", "purpose": "Formatter" },
      { "name": "rolldown", "version": "^1.0.0-rc.6", "purpose": "Bundler" },
      { "name": "tsx", "version": "^4.19.0", "purpose": "Dev runner" },
      { "name": "lefthook", "version": "^1.10.0", "purpose": "Git hooks" },
      { "name": "cspell", "version": "^8.19.4", "purpose": "Spell checker" },
      { "name": "@commitlint/cli", "version": "^19.0.0", "purpose": "Commit linting" }
    ]
  },
  "commands": {
    "dev": "npm run dev",
    "build": "npm run build",
    "start": "npm start",
    "check": "npm run check",
    "lint": "npm run lint",
    "fmt": "npm run fmt",
    "spell": "npm run spell",
    "test": "npm test",
    "testCoverage": "npm run test:coverage",
    "testE2E": "npm run test:e2e",
    "prepublish": "npm run prepublishOnly"
  },
  "codeStyle": {
    "imports": "ESM .js extensions required",
    "nullPolicy": "undefined only, no null (unicorn/no-null)",
    "objectKeys": "sorted alphabetically (sort-keys rule)",
    "typeDefinitions": "interface preferred over type",
    "async": "async/await + try/catch, no .then/.catch",
    "tests": "it() not test(), lowercase titles",
    "files": "kebab-case",
    "toolNames": "pinchtab_ prefix, snake_case"
  }
}

    },
    {
      "name": "tools/index",
      "path": "src/tools/index.ts",
      "exports": ["registerAllTools"],
      "purpose": "Barrel — calls all 4 register* functions"
    },
    {
      "name": "tools/shared",
      "path": "src/tools/shared.ts",
      "exports": ["waitAndSnapshot"],
      "purpose": "Shared tool helper: wait then return compact snapshot (used by navigate/click waitMs)"

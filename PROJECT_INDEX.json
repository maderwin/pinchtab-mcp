    {
      "name": "tools/instances",
      "path": "src/tools/instances.ts",
      "exports": ["registerInstanceTools"],
      "tools": ["pinchtab_list_instances", "pinchtab_close_tab", "pinchtab_health", "pinchtab_cookies"],
      "purpose": "Tab management (list, close), health check, cookies"

{
  "name": "pinchtab-mcp",
  "version": "1.1.0",
  "description": "MCP server for PinchTab browser automation — control Chrome via accessibility tree snapshots",
  "type": "module",
  "bin": {
    "pinchtab-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rolldown -c",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "oxlint -c oxlintrc.json --tsconfig tsconfig.json src/",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "PINCHTAB_E2E=1 vitest run -c vitest.e2e.config.ts",
    "spell": "cspell \"src/**/*.ts\" \"*.md\"",
    "check": "tsc --noEmit && npm run lint && npm run fmt:check && npm run spell && npm test",
    "prepublishOnly": "npm run check && npm run build",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "pinchtab": "*"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cspell": "^8.19.4",
    "lefthook": "^1.10.0",
    "lint-staged": "^15.3.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^0.16.0",
    "rolldown": "^1.0.0-rc.6",
    "semantic-release": "^25.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint -c oxlintrc.json --tsconfig tsconfig.json",
      "oxfmt --write",
      "cspell --no-must-find-files"
    ],
    "*.md": [
      "cspell --no-must-find-files"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maderwin/pinchtab-mcp.git"
  },
  "homepage": "https://maderwin.github.io/pinchtab-mcp",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "pinchtab",
    "browser",
    "automation",
    "accessibility",
    "chrome",
    "ai",
    "ai-agent",
    "claude",
    "headless",
    "stealth"
  ]
}
